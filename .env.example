# Copie estas variáveis para: Vercel Dashboard > seu projeto > Settings > Environment Variables
# Preencha com os valores reais SÓ no dashboard da Vercel — nunca aqui.
# Este arquivo pode ir pro GitHub sem problema, porque não tem segredo nenhum.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

